                        X
                    </button>
                </div>

                <div class="card-body">

                    <!-- FORM HEADER -->
                    <div class="row g-3">

                        <div class="col-md-3">
                            <label>Số phiếu</label>
                            <input class="form-control"
                                   @bind="model.So_Phieu_Nhap_Kho"
                                   />
                        </div>

                        <div class="col-md-3">
                            <label>Kho</label>
                            <select class="form-select"
                                    @bind="model.Kho_ID"
                                 >
                                <option value="">-- chọn kho --</option>
                                @foreach (var kho in listKho)
                                {
                                    <option value="@kho.Id">@kho.Ten_Kho</option>
                                }
                            </select>
                        </div>

                        <div class="col-md-3">
                            <label>Nhà cung cấp</label>
                            <select class="form-select"
                                    @bind="model.NCC_ID"
                                  >
                                <option value="">-- chọn NCC --</option>
                                @foreach (var ncc in listNCC)
                                {
                                    <option value="@ncc.Id">@ncc.Ten_NCC</option>
                                }
                            </select>
                        </div>

                        <div class="col-md-3">
                            <label>Ngày nhập</label>
                            <InputDate @bind-Value="model.Ngay_Nhap_Kho"
                                       class="form-control"
                                      />
                        </div>

                        <div class="col-md-12">
                            <label>Ghi chú</label>
                            <input class="form-control"
                                   @bind="model.Ghi_Chu"
                                  />
                        </div>

                    </div>
					<hr />

                    <!-- DETAIL -->
                    <button class="btn btn-warning"
                            @onclick="EnableEditDetail">
                        ✏️ Sửa chi tiết
                    </button>
                    <div class="d-flex justify-content-between mb-2">
                        <h5>Chi tiết sản phẩm</h5>
                        <button class="btn btn-sm text-white"
                                style="background:#6f42c1"
                                @onclick="AddCT">
                            + Thêm dòng
                        </button>
                    </div>

                    <table class="table table-bordered align-middle">
                        <thead class="table-secondary text-center">
                            <tr>
                                <th style="width:30%">Sản phẩm</th>
                                <th>Số lượng</th>
                                <th>Đơn giá</th>
                                <th>Trị giá</th>
                                <th width="80"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var ct in chiTietList)
                            {
                                <tr>
                                    <td>
                                        @if ( ct.Id == 0) // thêm mới
                                        {
                                            <select class="form-select" @bind="ct.San_Pham_ID">
                                                <option value="">-- chọn --</option>
                                                @foreach (var sp in listSanPham)
                                                {
                                                    <option value="@sp.Id">@sp.Ten_San_Pham</option>
                                                }
                                            </select>
                                        }
                                        else // edit
                                        {
                                            <input class="form-control"
                                                   value="@GetTenSP(ct.San_Pham_ID)"
                                                   disabled />
                                        }
                                    </td>

                                    <td>
                                        <input type="number"
                                               class="form-control text-end"
                                               @bind="ct.SL_Nhap" />
                                    </td>

                                    <td>
                                        <input type="number"
                                               class="form-control text-end"
                                               @bind="ct.Don_Gia_Nhap" />
                                    </td>

                                    <td class="text-end">
                                        @(ct.SL_Nhap * ct.Don_Gia_Nhap)
                                    </td>

                                    <td class="text-center">
                                        <button class="btn btn-sm btn-danger"
                                                @onclick="() => RemoveCT(ct)">
                                            X
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>

                    <!-- TOTAL -->
                    <div class="text-end fw-bold">
                        Tổng tiền:
                        @chiTietList.Sum(x => x.SL_Nhap * x.Don_Gia_Nhap)
                    </div>

                    <hr />

                    <!-- FOOTER -->
                    <div class="d-flex justify-content-end gap-2">
                        <button class="btn btn-danger"
                                @onclick="() => showForm = false">
                            Hủy
                        </button>

                        <button class="btn text-white"
                                style="background:#6f42c1"
                                @onclick="HandleSave">
                            💾 Lưu
                        </button>
                    </div>

                    @if(!string.IsNullOrEmpty(msg))
                    {
                        <div class="alert alert-info mt-2">@msg</div>
                    }
                </div>
            </div>
        </div>
    }

