    @* Bảng hiển thị *@
    <div class="table-responsive">
        <table class="table table-striped table-hover border">
            <thead class="table-dark">
                <tr>
                    <td>Id</td>
                    <td>Số phiếu nhập kho</td>
                    <td>Kho</td>
                    <td>Nhà cung cấp</td>
                    <th>Ngày nhập kho</th>
                    <th>Ghi chú</th>
                    <th class="text-center" width="180">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (listData == null)
                {
                    <tr><td colspan="7" class="text-center">Đang tải dữ liệu từ API...</td></tr>
                }
                else if (listData.Count == 0)
                {
                    <tr><td colspan="7" class="text-center">Chưa có dữ liệu nào.</td></tr>
                }
                else
                {
                    @foreach (var item in listData)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td>@item.So_Phieu_Nhap_Kho</td>
                            <td>@item.Ten_Kho</td>
                            <td>@item.Ten_NCC</td>
                            <td>@item.Ngay_Nhap_Kho</td>
                            <td>@item.Ghi_Chu</td>
                            <td class="text-center">
                                <div class="btn-group">

                                    <button class="btn btn-sm btn-warning"
                                            title="Sửa header"
                                            @onclick="() => LoadEditHeader(item)">
                                        <i class="bi bi-pencil-square"></i>
                                        Header
                                    </button>

                                    <button class="btn btn-sm btn-warning"
                                            title="Sửa chi tiết"
                                            @onclick="() => LoadEditDetail(item)">
                                        <i class="bi bi-list"></i>
                                        Detail
                                    </button>

                                    <button class="btn btn-sm btn-success"
                                            title="In phiếu">
                                        <i class="bi bi-printer"></i>
                                        In
                                    </button>

                                    <button class="btn btn-sm btn-danger"
                                            title="Xóa"
                                            @onclick="() => Delete(item.Id)">
                                        <i class="bi bi-trash"></i>
                                        Xoá
                                    </button>

                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@code {

    private List<NhapKhoDto>? listData;
    private List<KhoDto>? listKho = new();
    private List<NhaCungCapDto>? listNCC = new();

    // List<NhapKhoDto> listData = new List<NhapKhoDto>
    // {
    //     new NhapKhoDto{Id = 1,So_Phieu_Nhap_Kho = "001",Kho_ID = 1, NCC_ID = 1,Ngay_Nhap_Kho = new DateTime(2026,1,1), Ghi_Chu = "Note", Details = new List<NhapKhoDetailDto> { new NhapKhoDetailDto {Id = 1, Nhap_Kho_ID = 1, San_Pham_ID = 1, SL_Nhap = 2, Don_Gia_Nhap = 0m } } },
    //     new NhapKhoDto{Id = 2,So_Phieu_Nhap_Kho = "002",Kho_ID = 2, NCC_ID = 2,Ngay_Nhap_Kho = new DateTime(2026,1,2), Ghi_Chu = "Note", Details = new List<NhapKhoDetailDto> { new NhapKhoDetailDto {Id = 2, Nhap_Kho_ID = 2, San_Pham_ID = 2, SL_Nhap = 5, Don_Gia_Nhap = 0m } } },
    //     new NhapKhoDto{Id = 3,So_Phieu_Nhap_Kho = "003",Kho_ID = 3, NCC_ID = 3,Ngay_Nhap_Kho = new DateTime(2026,1,3), Ghi_Chu = "Note", Details = new List<NhapKhoDetailDto> { new NhapKhoDetailDto {Id = 3, Nhap_Kho_ID = 3, San_Pham_ID = 3, SL_Nhap = 9, Don_Gia_Nhap = 0m } } },
    //     new NhapKhoDto{Id = 4,So_Phieu_Nhap_Kho = "004",Kho_ID = 4, NCC_ID = 4,Ngay_Nhap_Kho = new DateTime(2026,1,4), Ghi_Chu = "Note", Details = new List<NhapKhoDetailDto> { new NhapKhoDetailDto {Id = 4, Nhap_Kho_ID = 4, San_Pham_ID = 4, SL_Nhap = 3, Don_Gia_Nhap = 0m } } },
    //     new NhapKhoDto{Id = 5,So_Phieu_Nhap_Kho = "005",Kho_ID = 5, NCC_ID = 5,Ngay_Nhap_Kho = new DateTime(2026,1,5), Ghi_Chu = "Note", Details = new List<NhapKhoDetailDto> { new NhapKhoDetailDto {Id = 5, Nhap_Kho_ID = 5, San_Pham_ID = 5, SL_Nhap = 4, Don_Gia_Nhap = 0m } } },
    // };

    private NhapKhoDto model = new();
    private bool showForm = false;
    private string msg = "";

    private bool isEdit = false;
    private bool isEditDetailForm = false;
    private bool isEditHeaderForm = false;

    // chi tiet

    private List<NhapKhoDetailDto> chiTietList = new();
    private List<SanPhamDto>? listSanPham = new();

    private void AddCT()
    {
        chiTietList.Add(new NhapKhoDetailDto());
    }

    private void RemoveCT(NhapKhoDetailDto ct)
    {
        chiTietList.Remove(ct);
    }

    private void EnableEditDetail()
    {
        isEditDetailForm = true;
    }
    private void EnableEditHeader()
    {
        isEditHeaderForm = true;
    }
    private string GetTenSP(int id)
    {
        return listSanPham.FirstOrDefault(x => x.Id == id)?.Ten_San_Pham ?? "";
    }
    //

    protected override async Task OnInitializedAsync()
    {
        await LoadList();
        await LoadDropdown();
        isEditDetailForm = false;
        isEditHeaderForm = false;
        model.ChiTiets = chiTietList;
    }

    private async Task LoadList()
    {
        try
        {
            listData = await Http.GetFromJsonAsync<List<NhapKhoDto>>("api/NhapKho");
        }
        catch
        {
            msg = "Lỗi khi lấy thông tin nhập kho";
        }
    }

    private async Task LoadDropdown()
    {
        try
        {
            listKho = await Http.GetFromJsonAsync<List<KhoDto>>("api/Kho");
            listNCC = await Http.GetFromJsonAsync<List<NhaCungCapDto>>("api/NhaCungCap");
            listSanPham = await Http.GetFromJsonAsync<List<SanPhamDto>>("api/SanPham");
        }
        catch
        {
            msg = "Lỗi không lấy được dữ liệu kho hoặc nhà cung cấp";
        }
    }

    private async Task HandleSave()
    {
        if (string.IsNullOrEmpty(model.So_Phieu_Nhap_Kho))
        {
            msg = "Vui lòng nhập số phiếu nhập kho!";
            return;
        }

        if(model.Kho_ID <= 0)
        {
            msg = "Kho không hợp lệ";
            return;
        }

        if(model.NCC_ID <= 0)
        {
            msg = "Nhà cung cấp không hợp lệ";
            return;
        }

        if(model.Ngay_Nhap_Kho == null)
        {
            msg = "Vui lòng chọn ngày nhập kho";
            return;
        }

        if (chiTietList.Count == 0)
        {
            msg = "Phải có ít nhất 1 sản phẩm!";
            return;
        }

         model.ChiTiets = chiTietList;

        if (isEdit)
        {

            try
            {
                await Http.PutAsJsonAsync($"api/NhapKho/{model.Id}", model);
                msg = "Cập nhật thành công!";
            }
            catch
            {
                msg = "Lỗi khi cập nhật nhập kho";
            }
        }
        else
        {
            try
            {
                var res = await Http.PostAsJsonAsync("api/NhapKho", model);
                if (res.IsSuccessStatusCode) msg = "Thêm mới thành công!";
                else
                {
                    var error = await res.Content.ReadAsStringAsync();
                    msg = error;
                }
            }
            catch
            {  
                msg = "Lỗi khi thêm phiếu nhập kho";
            }
        }

        model = new();
        isEdit = false;
        await LoadList();
    }

    private async Task HandleSaveHeader()
    {
        if (string.IsNullOrEmpty(model.So_Phieu_Nhap_Kho))
        {
            msg = "Vui lòng nhập số phiếu nhập kho!";
            return;
        }

        if (model.Kho_ID <= 0)
        {
            msg = "Kho không hợp lệ";
            return;
        }

        if (model.NCC_ID <= 0)
        {
            msg = "Nhà cung cấp không hợp lệ";
            return;
        }

        if (model.Ngay_Nhap_Kho == null)
        {
            msg = "Vui lòng chọn ngày nhập kho";
            return;
        }

        if (chiTietList.Count == 0)
        {
            msg = "Phải có ít nhất 1 sản phẩm!";
            return;
        }

        model.ChiTiets = chiTietList;

        
            try
            {
            var res = await Http.PostAsJsonAsync("api/XNKNhapKho/adjustment", model);
                if (res.IsSuccessStatusCode) msg = "Thêm mới thành công!";
                else
                {
                    var error = await res.Content.ReadAsStringAsync();
                    msg = error;
                }
            }
            catch
            {
                msg = "Lỗi khi cap nhat phiếu nhập kho";
            }

        model = new();
        //isEdit = false;
        await LoadList();
    }

