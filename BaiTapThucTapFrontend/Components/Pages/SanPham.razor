     @if (showForm)
    {
        <div class="overlay">
            <div class="form-popup card shadow">
                <div class="card-header text-white" style="background:#6f42c1">
                    <h5>@(isEdit ? "Cập nhật" : "Thêm mới") sản phẩm</h5>
                </div>

                <div class="card-body">
                    <div class="mb-3">
                        <label>Mã sản phẩm</label>
                        <input class="form-control" @bind="model.Ma_San_Pham" placeholder="VD SP001, SP002,..."/>
                    </div>
                    <div class="mb-3">
                        <label>Tên sản phẩm</label>
                        <input class="form-control" @bind="model.Ten_San_Pham" placeholder="VD Sản phẩm 1,..."/>
                    </div>
                    <div class="mb-3">
                        <label>Kho</label>
                        <select class="form-select" @bind="model.Loai_San_Pham_ID">
                            <option value="">-- Chọn loại sản phẩm --</option>
                            @foreach (var lsp in listLoaiSanPham)
                            {
                                <option value="@lsp.Id">@lsp.Ten_LSP</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label>Đơn vị tính</label>
                        <select class="form-select" @bind="model.Don_Vi_Tinh_ID">
                            <option value="">-- Chọn đơn vị tính --</option>
                            @foreach (var dvt in listDonViTinh)
                            {
                                <option value="@dvt.Id">@dvt.Ten_Don_Vi_Tinh</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label>Ghi chú</label>
                        <input class="form-control" @bind="model.Ghi_Chu" placeholder="Nhập ghi chú nếu có"/>
                    </div>

                    <div class="d-flex justify-content-end gap-2">
                        <button class="btn btn-danger"
                                @onclick="() => {showForm = false; isEdit = false;}">
                            Hủy
                        </button>

                        <button class="btn text-white"
                                style="background:#6f42c1"
                                @onclick="HandleSave">
                            Lưu
                        </button>
                    </div>

                    @if (!string.IsNullOrEmpty(msg))
                    {
                        <div class="alert alert-info mt-2">@msg</div>
                    }
                </div>
            </div>
        </div>
    }

    @* Bảng hiển thị *@
    <div class="table-responsive">
        <table class="table table-striped table-hover border">
            <thead class="table-dark">
                <tr>
                    <td>Id</td>
                    <td>Mã sản phẩm</td>
                    <td>Tên sản phẩm</td>
                    <td>Loại sản phẩm</td>
                    <th>Đơn vị tính</th>
                    <th>Ghi Chú</th>
                    <th class="text-center" width="180">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (listData == null)
                {
                    <tr><td colspan="7" class="text-center">Đang tải dữ liệu từ API...</td></tr>
                }
                else if (listData.Count == 0)
                {
                    <tr><td colspan="7" class="text-center">Chưa có dữ liệu nào.</td></tr>
                }
                else
                {
                    foreach (var item in listData)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td>@item.Ma_San_Pham</td>
                            <td>@item.Ten_San_Pham</td>
                            <td>@item.Don_Vi_Tinh_ID</td>
                            <td>@item.Loai_San_Pham_ID</td>
                            <td>@item.Ghi_Chu</td>
                            <td class="text-center">
                                <button class="btn btn-sm btn-warning me-1" @onclick="() => LoadEdit(item)">Sửa</button>
                                <button class="btn btn-sm btn-danger" @onclick="() => Delete(item.Id)">Xóa</button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@code {

    private List<SanPhamDto>? listData;
    private List<DonViTinhDto>? listDonViTinh = new();
    private List<LoaiSanPhamDto>? listLoaiSanPham = new();

    // List<SanPhamDto> listData = new List<SanPhamDto>
    // {
    //     new SanPhamDto{Id = 1,Ma_San_Pham = "a",Ten_San_Pham = "a1",Loai_San_Pham_ID = 1,Don_Vi_Tinh_ID = 1, Ghi_Chu = "Note"},
    //     new SanPhamDto{Id = 2,Ma_San_Pham = "b",Ten_San_Pham = "a2",Loai_San_Pham_ID = 2,Don_Vi_Tinh_ID = 2, Ghi_Chu = "Note"},
    //     new SanPhamDto{Id = 3,Ma_San_Pham = "c",Ten_San_Pham = "a3",Loai_San_Pham_ID = 3,Don_Vi_Tinh_ID = 3, Ghi_Chu = "Note"},
    //     new SanPhamDto{Id = 4,Ma_San_Pham = "d",Ten_San_Pham = "a4",Loai_San_Pham_ID = 4,Don_Vi_Tinh_ID = 4, Ghi_Chu = "Note"},
    //     new SanPhamDto{Id = 5,Ma_San_Pham = "e",Ten_San_Pham = "a5",Loai_San_Pham_ID = 5,Don_Vi_Tinh_ID = 5, Ghi_Chu = "Note"},
    // };

    private SanPhamDto model = new();
    private bool showForm = false;
    private string msg = "";
    private bool isEdit = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadList();
    }

    private async Task LoadList()
    {
        try
        {
            listData = await Http.GetFromJsonAsync<List<SanPhamDto>>("api/SanPham");
        }
        catch
        {
            msg = "Lỗi khi lấy thông tin sản phẩm";
        }
    }
    private async Task LoadDropdown()
    {
        try{
            listDonViTinh = await Http.GetFromJsonAsync<List<DonViTinhDto>>("api/DonViTinh");
            listLoaiSanPham = await Http.GetFromJsonAsync<List<LoaiSanPhamDto>>("api/LoaiSanPham");
        }
        catch
        {
            msg = "Lỗi khi lấy thông tin đơn vị tính hoặc loại sản phẩm";
        }
    }

    private async Task HandleSave()
    {
        if (string.IsNullOrEmpty(model.Ma_San_Pham))
        {
            msg = "Vui lòng nhập mã sản phẩm!";
            return;
        }

        if (string.IsNullOrEmpty(model.Ten_San_Pham))
        {
            msg = "Vui lòng nhập tên sản phẩm";
            return;
        }

        if(model.Don_Vi_Tinh_ID <= 0)
        {
            msg = "Đơn vị tính không hợp lệ";
            return;
        }

        if(model.Loai_San_Pham_ID <= 0)
        {
            msg = "Loại sản phẩm không hợp lệ";
            return;
        }

        if (isEdit)
        {
            try{
                await Http.PutAsJsonAsync($"api/SanPham/{model.Id}", model);
                msg = "Cập nhật thành công!";
            }
            catch
            {
                msg = "Lỗi khi cập nhật sản phẩm";
            }
        }
        else
        {
            try
            {
                var res = await Http.PostAsJsonAsync("api/SanPham", model);
                if (res.IsSuccessStatusCode) msg = "Thêm mới thành công!";
                else
                {
                    var error = await res.Content.ReadAsStringAsync();
                    msg = error;
                }
            }
            catch
            {
                msg = "Lỗi khi thêm sản phẩm";
            }
        }

        model = new();
        isEdit = false;
        await LoadList();
    }

    private void LoadEdit(SanPhamDto item)
    {
        model = new SanPhamDto { Id = item.Id,Ma_San_Pham = item.Ma_San_Pham,Ten_San_Pham = item.Ten_San_Pham, Don_Vi_Tinh_ID = item.Don_Vi_Tinh_ID, Loai_San_Pham_ID = item.Loai_San_Pham_ID, Ghi_Chu = item.Ghi_Chu };
        isEdit = true;
        showForm = true;
        msg = "Đang ở chế độ chỉnh sửa.";
    }

    private async Task Delete(int id)
    {
        bool confirm = await JS.InvokeAsync<bool>("confirm", "Bạn có chắc muốn xóa san pham này?");
        if (confirm)
        {
            try
            {
                await Http.DeleteAsync($"api/SanPham/{id}");
                await LoadList();
            }
            catch
            {
                msg = "Lỗi khi xoá sản phẩm";
            }
        }
    }
}