@page "/san-pham"
@using System.Net.Http.Json
@using BaiTapThucTapFrontend.Models
@inject HttpClient Http
@inject IJSRuntime JS

<div class="container-fluid">
    <h3 class="mt-3">Quản lý San pham</h3>

    @* Form nhập liệu nhanh *@
    <div class="card my-3">
        <div class="card-body bg-light">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Ma san pham (*)</label>
                    <input type="text" class="form-control" @bind="model.Ma_San_Pham" placeholder="Ví dụ: 001,002..." />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Ten san pham (*)</label>
                    <input type="text" class="form-control" @bind="model.Ten_San_Pham" placeholder="Ví dụ: San pham1,San pham2,..." />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Loai san pham (*)</label>
                    <input type="text" class="form-control" @bind="model.Loai_San_Pham_ID" placeholder="" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Don vi tinh (*)</label>
                    <input type="text" class="form-control" @bind="model.Don_Vi_Tinh_ID" placeholder="" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Ghi chú</label>
                    <input type="text" class="form-control" @bind="model.Ghi_Chu" placeholder="Nhập ghi chú nếu có..." />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button class="btn btn-primary w-100" @onclick="HandleSave">
                        <i class="bi bi-save"></i> Lưu dữ liệu
                    </button>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(msg))
            {
                <div class="alert alert-info mt-2 py-1">@msg</div>
            }
        </div>
    </div>

    @* Bảng hiển thị *@
    <div class="table-responsive">
        <table class="table table-striped table-hover border">
            <thead class="table-dark">
                <tr>
                    <td>Ma san pham</td>
                    <td>Ten san pham</td>
                    <td>Loai san pham</td>
                    <th>Đơn vị tính</th>
                    <th>Ghi Chú</th>
                    <th class="text-center" width="180">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (listData == null)
                {
                    <tr><td colspan="3" class="text-center">Đang tải dữ liệu từ API...</td></tr>
                }
                else if (listData.Count == 0)
                {
                    <tr><td colspan="3" class="text-center">Chưa có dữ liệu nào.</td></tr>
                }
                else
                {
                    foreach (var item in listData)
                    {
                        <tr>
                            <td>@item.Ma_San_Pham</td>
                            <td>@item.Ten_San_Pham</td>
                            <td>@item.Don_Vi_Tinh_ID</td>
                            <td>@item.Loai_San_Pham_ID</td>
                            <td>@item.Ghi_Chu</td>
                            <td class="text-center">
                                <button class="btn btn-sm btn-warning me-1" @onclick="() => LoadEdit(item)">Sửa</button>
                                <button class="btn btn-sm btn-danger" @onclick="() => Delete(item.Id)">Xóa</button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@code {

    //private List<DonViTinhDto>? listData;

    List<SanPhamDto> listData = new List<SanPhamDto>
    {
        new SanPhamDto{Id = 1,Ma_San_Pham = "a",Ten_San_Pham = "a1",Loai_San_Pham_ID = 1,Don_Vi_Tinh_ID = 1, Ghi_Chu = "Note"},
        new SanPhamDto{Id = 2,Ma_San_Pham = "b",Ten_San_Pham = "a2",Loai_San_Pham_ID = 2,Don_Vi_Tinh_ID = 2, Ghi_Chu = "Note"},
        new SanPhamDto{Id = 3,Ma_San_Pham = "c",Ten_San_Pham = "a3",Loai_San_Pham_ID = 3,Don_Vi_Tinh_ID = 3, Ghi_Chu = "Note"},
        new SanPhamDto{Id = 4,Ma_San_Pham = "d",Ten_San_Pham = "a4",Loai_San_Pham_ID = 4,Don_Vi_Tinh_ID = 4, Ghi_Chu = "Note"},
        new SanPhamDto{Id = 5,Ma_San_Pham = "e",Ten_San_Pham = "a5",Loai_San_Pham_ID = 5,Don_Vi_Tinh_ID = 5, Ghi_Chu = "Note"},
    };

    private SanPhamDto model = new();
    private string msg = "";
    private bool isEdit = false;

    // protected override async Task OnInitializedAsync()
    // {
    //     await LoadList();
    // }

    // private async Task LoadList()
    // {
    //     // Nhớ chỉnh lại "api/DonViTinh" cho đúng Route bên Backend của em
    //     listData = await Http.GetFromJsonAsync<List<DonViTinhDto>>("api/DonViTinh");
    // }

    private async Task HandleSave()
    {
        if (string.IsNullOrEmpty(model.Ma_San_Pham))
        {
            msg = "Vui lòng nhập ma san pham!";
            return;
        }

        if (string.IsNullOrEmpty(model.Ten_San_Pham))
        {
            msg = "Vui long nhap ten san pham";
            return;
        }

        if(model.Don_Vi_Tinh_ID <= 0)
        {
            msg = "Don vi tinh khong hop le";
            return;
        }

        if(model.Loai_San_Pham_ID <= 0)
        {
            msg = "Loai san pham khong hop le";
            return;
        }

        if (isEdit)
        {
            await Http.PutAsJsonAsync($"api/SanPham/{model.Id}", model);
            msg = "Cập nhật thành công!";
        }
        else
        {
            var res = await Http.PostAsJsonAsync("api/SanPham", model);
            if (res.IsSuccessStatusCode) msg = "Thêm mới thành công!";
            else msg = "Lỗi: !";
        }

        model = new();
        isEdit = false;
        //await LoadList();
    }

    private void LoadEdit(SanPhamDto item)
    {
        model = new SanPhamDto { Id = item.Id,Ma_San_Pham = item.Ma_San_Pham,Ten_San_Pham = item.Ten_San_Pham, Don_Vi_Tinh_ID = item.Don_Vi_Tinh_ID, Loai_San_Pham_ID = item.Loai_San_Pham_ID, Ghi_Chu = item.Ghi_Chu };
        isEdit = true;
        msg = "Đang ở chế độ chỉnh sửa.";
    }

    private async Task Delete(int id)
    {
        bool confirm = await JS.InvokeAsync<bool>("confirm", "Bạn có chắc muốn xóa san pham này?");
        if (confirm)
        {
            await Http.DeleteAsync($"api/SanPham/{id}");
            // await LoadList();
        }
    }
}