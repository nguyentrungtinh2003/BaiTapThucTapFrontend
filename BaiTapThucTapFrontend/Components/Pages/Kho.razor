    @if (showForm)
    {
        <div class="overlay">
            <div class="form-popup card shadow">
                <div class="card-header text-white" style="background:#6f42c1">
                    <h5>@(isEdit ? "Cập nhật" : "Thêm mới") kho</h5>
                </div>

                <div class="card-body">
                    <div class="mb-3">
                        <label>Tên kho</label>
                        <input class="form-control" @bind="model.Ten_Kho" placeholder="VD Kho1, Kho2,..."/>
                    </div>

                    <div class="mb-3">
                        <label>Ghi chú</label>
                        <input class="form-control" @bind="model.Ghi_Chu" placeholder="Nhập ghi chú nếu có"/>
                    </div>

                    <div class="d-flex justify-content-end gap-2">
                        <button class="btn btn-danger"
                                @onclick="() => {showForm = false; isEdit = false;}">
                            Hủy
                        </button>

                        <button class="btn text-white"
                                style="background:#6f42c1"
                                @onclick="HandleSave">
                            Lưu
                        </button>
                    </div>

                    @if (!string.IsNullOrEmpty(msg))
                    {
                        <div class="alert alert-info mt-2">@msg</div>
                    }
                </div>
            </div>
        </div>
    }

    @* Bảng hiển thị *@
    <div class="table-responsive">
        <table class="table table-striped table-hover border">
            <thead class="table-dark">
                <tr>
                    <th>Id</th>
                    <th>Tên kho</th>
                    <th>Ghi chú</th>
                    <th class="text-center" width="180">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (listData == null)
                {
                    <tr><td colspan="4" class="text-center">Đang tải dữ liệu từ API...</td></tr>
                }
                else if (listData.Count == 0)
                {
                    <tr><td colspan="4" class="text-center">Chưa có dữ liệu nào.</td></tr>
                }
                else
                {
                    foreach (var item in listData)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td>@item.Ten_Kho</td>
                            <td>@item.Ghi_Chu</td>
                            <td class="text-center">
                                <button class="btn btn-sm btn-warning me-1" @onclick="() => LoadEdit(item)">Sửa</button>
                                <button class="btn btn-sm btn-danger" @onclick="() => Delete(item.Id)">Xóa</button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@code {

    private List<KhoDto>? listData;

    // List<KhoDto> listData = new List<KhoDto>
    // {
    //     new KhoDto{Id = 1,Ten_Kho = "Kho1",Ghi_Chu = "Note"},
    //     new KhoDto{Id = 2,Ten_Kho = "Kho2",Ghi_Chu = "Note"},
    //     new KhoDto{Id = 3,Ten_Kho = "Kho3",Ghi_Chu = "Note"},
    //     new KhoDto{Id = 4,Ten_Kho = "Kho4",Ghi_Chu = "Note"},
    //     new KhoDto{Id = 5,Ten_Kho = "Kho5",Ghi_Chu = "Note"},
    // };

    private KhoDto model = new();
    private bool showForm = false;
    private string msg = "";
    private bool isEdit = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadList();
    }

    private async Task LoadList()
    {
        try
        {
            listData = await Http.GetFromJsonAsync<List<KhoDto>>("api/Kho");
        }
        catch
        {
            msg = "Lỗi khi lấy dữ liệu kho";
        }
    }

    private async Task HandleSave()
    {
        if (string.IsNullOrEmpty(model.Ten_Kho))
        {
            msg = "Vui lòng nhập ten kho!";
            return;
        }

        if (isEdit)
        {
            try
            {
                await Http.PutAsJsonAsync($"api/Kho/{model.Id}", model);
                msg = "Cập nhật thành công!";
            }
            catch
            {
                msg = "Lỗi khi cập nhật kho";
            }
        }
        else
        {
            try
            {
                var res = await Http.PostAsJsonAsync("api/Kho", model);
                if (res.IsSuccessStatusCode) msg = "Thêm mới thành công!";
                else
                {
                    var error = await res.Content.ReadAsStringAsync();
                    msg = error;
                }
            }
            catch
            {
                 msg = "Lỗi khi thêm kho";
            }
        }

        model = new();
        isEdit = false;
        await LoadList();
    }

    private void LoadEdit(KhoDto item)
    {
        model = new KhoDto { Id = item.Id, Ten_Kho = item.Ten_Kho, Ghi_Chu = item.Ghi_Chu };
        isEdit = true;
        showForm = true;
        msg = "Đang ở chế độ chỉnh sửa.";
    }

    private async Task Delete(int id)
    {
        bool confirm = await JS.InvokeAsync<bool>("confirm", "Bạn có chắc muốn xóa kho này?");
        if (confirm)
        {
            try
            {
                await Http.DeleteAsync($"api/Kho/{id}");
                await LoadList();
            }
            catch
            {
                msg = "Lỗi khi xoá kho";
            }
        }
    }
}