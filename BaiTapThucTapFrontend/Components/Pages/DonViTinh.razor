@page "/don-vi-tinh"
@using System.Net.Http.Json
@using BaiTapThucTapFrontend.Models
@inject HttpClient Http
@inject IJSRuntime JS

<div class="container-fluid">
    <h3 class="mt-3">Quản lý Don vi tinh</h3>

    @* Form nhập liệu nhanh *@
    <div class="card my-3">
        <div class="card-body bg-light">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Tên don vi tinh (*)</label>
                    <input type="text" class="form-control" @bind="model.Ten_Don_Vi_Tinh" placeholder="Ví dụ: Cai, thung,..." />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Ghi chú</label>
                    <input type="text" class="form-control" @bind="model.Ghi_Chu" placeholder="Nhập ghi chú nếu có..." />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button class="btn btn-primary w-100" @onclick="HandleSave">
                        <i class="bi bi-save"></i> Lưu dữ liệu
                    </button>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(msg))
            {
                <div class="alert alert-info mt-2 py-1">@msg</div>
            }
        </div>
    </div>

    @* Bảng hiển thị *@
    <div class="table-responsive">
        <table class="table table-striped table-hover border">
            <thead class="table-dark">
                <tr>
                    <th>Id</th>
                    <th>Ten don vi tinh</th>
                    <th>Ghi Chú</th>
                    <th class="text-center" width="180">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (listData == null)
                {
                    <tr><td colspan="3" class="text-center">Đang tải dữ liệu từ API...</td></tr>
                }
                else if (listData.Count == 0)
                {
                    <tr><td colspan="3" class="text-center">Chưa có dữ liệu nào.</td></tr>
                }
                else
                {
                    foreach (var item in listData)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td>@item.Ten_Don_Vi_Tinh</td>
                            <td>@item.Ghi_Chu</td>
                            <td class="text-center">
                                <button class="btn btn-sm btn-warning me-1" @onclick="() => LoadEdit(item)">Sửa</button>
                                <button class="btn btn-sm btn-danger" @onclick="() => Delete(item.Id)">Xóa</button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@code {

    //private List<DonViTinhDto>? listData;

    List<DonViTinhDto> listData = new List<DonViTinhDto> {
        new DonViTinhDto { Id = 1, Ten_Don_Vi_Tinh = "Kg", Ghi_Chu = "Note" },
        new DonViTinhDto { Id = 2, Ten_Don_Vi_Tinh = "Cai", Ghi_Chu = "Note" },
        new DonViTinhDto { Id = 3, Ten_Don_Vi_Tinh = "Thung", Ghi_Chu = "Note" },
        new DonViTinhDto { Id = 4, Ten_Don_Vi_Tinh = "Bo", Ghi_Chu = "Note" },
        new DonViTinhDto { Id = 5, Ten_Don_Vi_Tinh = "Mieng", Ghi_Chu = "Note" }, };

    private DonViTinhDto model = new();
    private string msg = "";
    private bool isEdit = false;

    // protected override async Task OnInitializedAsync()
    // {
    //     await LoadList();
    // }

    // private async Task LoadList()
    // {
    //     // Nhớ chỉnh lại "api/DonViTinh" cho đúng Route bên Backend của em
    //     listData = await Http.GetFromJsonAsync<List<DonViTinhDto>>("api/DonViTinh");
    // }

    private async Task HandleSave()
    {
        if (string.IsNullOrEmpty(model.Ten_Don_Vi_Tinh))
        {
            msg = "Vui lòng nhập ten don vi tinh!";
            return;
        }

        if (isEdit)
        {
            await Http.PutAsJsonAsync($"api/DonViTinh/{model.Id}", model);
            msg = "Cập nhật thành công!";
        }
        else
        {
            var res = await Http.PostAsJsonAsync("api/DonViTinh", model);
            if (res.IsSuccessStatusCode) msg = "Thêm mới thành công!";
            else msg = "Lỗi: Kho có thể đã tồn tại!";
        }

        model = new();
        isEdit = false;
        //await LoadList();
    }

    private void LoadEdit(DonViTinhDto item)
    {
        model = new DonViTinhDto { Id = item.Id, Ten_Don_Vi_Tinh = item.Ten_Don_Vi_Tinh, Ghi_Chu = item.Ghi_Chu };
        isEdit = true;
        msg = "Đang ở chế độ chỉnh sửa.";
    }

    private async Task Delete(int id)
    {
        bool confirm = await JS.InvokeAsync<bool>("confirm", "Bạn có chắc muốn xóa don vi tinh này?");
        if (confirm)
        {
            await Http.DeleteAsync($"api/DonViTinh/{id}");
            // await LoadList();
        }
    }
}