    @if (showForm)
    {
        <div class="overlay">
            <div class="form-popup card shadow">
                <div class="card-header text-white" style="background:#6f42c1">
                    <h5>@(isEdit ? "Cập nhật" : "Thêm mới") đơn vị tính</h5>
                </div>

                <div class="card-body">
                    <div class="mb-3">
                        <label>Tên đơn vị tính</label>
                        <input class="form-control" @bind="model.Ten_Don_Vi_Tinh" placeholder="VD Cái, Thùng, Bộ,..." />
                    </div>

                    <div class="mb-3">
                        <label>Ghi chú</label>
                        <input class="form-control" @bind="model.Ghi_Chu" placeholder="Nhập ghi chú nếu có"/>
                    </div>

                    <div class="d-flex justify-content-end gap-2">
                        <button class="btn btn-danger"
                                @onclick="() => {showForm = false; isEdit = false;}">
                            Hủy
                        </button>

                        <button class="btn text-white"
                                style="background:#6f42c1"
                                @onclick="HandleSave">
                            Lưu
                        </button>
                    </div>

                    @if (!string.IsNullOrEmpty(msg))
                    {
                        <div class="alert alert-info mt-2">@msg</div>
                    }
                </div>
            </div>
        </div>
    }

    @* Bảng hiển thị *@
    <div class="table-responsive">
        <table class="table table-striped table-hover border">
            <thead class="table-dark">
                <tr>
                    <th>Id</th>
                    <th>Tên đơn vị tính</th>
                    <th>Ghi Chú</th>
                    <th class="text-center" width="180">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (listData == null)
                {
                    <tr><td colspan="4" class="text-center">Đang tải dữ liệu từ API...</td></tr>
                }
                else if (listData.Count == 0)
                {
                    <tr><td colspan="4" class="text-center">Chưa có dữ liệu nào.</td></tr>
                }
                else
                {
                    foreach (var item in listData)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td>@item.Ten_Don_Vi_Tinh</td>
                            <td>@item.Ghi_Chu</td>
                            <td class="text-center">
                                <button class="btn btn-sm btn-warning me-1" @onclick="() => LoadEdit(item)">Sửa</button>
                                <button class="btn btn-sm btn-danger" @onclick="() => Delete(item.Id)">Xóa</button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@code {

    private List<DonViTinhDto>? listData;

    // List<DonViTinhDto> listData = new List<DonViTinhDto> {
    //     new DonViTinhDto { Id = 1, Ten_Don_Vi_Tinh = "Kg", Ghi_Chu = "Note" },
    //     new DonViTinhDto { Id = 2, Ten_Don_Vi_Tinh = "Cai", Ghi_Chu = "Note" },
    //     new DonViTinhDto { Id = 3, Ten_Don_Vi_Tinh = "Thung", Ghi_Chu = "Note" },
    //     new DonViTinhDto { Id = 4, Ten_Don_Vi_Tinh = "Bo", Ghi_Chu = "Note" },
    //     new DonViTinhDto { Id = 5, Ten_Don_Vi_Tinh = "Mieng", Ghi_Chu = "Note" }, };

    private DonViTinhDto model = new();
    private string msg = "";
    private bool isEdit = false;
    private bool showForm = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadList();
    }

    private async Task LoadList()
    {
        try
        {
            listData = await Http.GetFromJsonAsync<List<DonViTinhDto>>("api/DonViTinh");
        }
        catch
        {
            msg = "Lỗi khi lấy dữ liệu đơn vị tính";
            listData = new List<DonViTinhDto>();
        }
    }

    private async Task HandleSave()
    {
        if (string.IsNullOrEmpty(model.Ten_Don_Vi_Tinh))
        {
            msg = "Vui lòng nhập ten don vi tinh!";
            return;
        }

        if (isEdit)
        {
            try
            {
                await Http.PutAsJsonAsync($"api/DonViTinh/{model.Id}", model);
                msg = "Cập nhật thành công!";
                showForm = false;
            }
            catch
            {
                msg = "Lỗi khi cập nhật đơn vị tính";
            }
        }
        else
        {
            try
            {
                var res = await Http.PostAsJsonAsync("api/DonViTinh", model);
                Console.WriteLine("Model " + model.Ten_Don_Vi_Tinh + " "+ model.Ghi_Chu);
                if (res.IsSuccessStatusCode)
                {
                    msg = "Thêm mới thành công!";
                    showForm = false;
                }
                else
                {
                    var error = await res.Content.ReadAsStringAsync();
                    msg = error;
                }
            }
            catch
            {
                msg = "Lỗi khi thêm đơn vị tính";
            }
        }

        model = new();
        isEdit = false;
        await LoadList();
    }

    private void LoadEdit(DonViTinhDto item)
    {
        model = new DonViTinhDto { Id = item.Id, Ten_Don_Vi_Tinh = item.Ten_Don_Vi_Tinh, Ghi_Chu = item.Ghi_Chu };
        isEdit = true;
        showForm = true;
    }

    private async Task Delete(int id)
    {
        bool confirm = await JS.InvokeAsync<bool>("confirm", "Bạn có chắc muốn xóa don vi tinh này?");
        if (confirm)
        {
            try
            {
                await Http.DeleteAsync($"api/DonViTinh/{id}");
                await LoadList();
            }
            catch
            {
                msg = "Lỗi khi xoá đơn vị tính";
            }
        }
    }
}