@page "/loai-san-pham"
@using System.Net.Http.Json
@using BaiTapThucTapFrontend.Models
@inject HttpClient Http
@inject IJSRuntime JS
@rendermode InteractiveServer

<div class="container-fluid">
    <h3 class="mt-3">Quản Lý Loại Sản Phẩm</h3>

    <button class="btn text-white mb-3"
            style="background-color:#6f42c1"
            @onclick="() => showForm = true">
        + Thêm loại sản phẩm
    </button>

    @* Form nhập liệu nhanh *@
   @*  <div class="card my-3">
        <div class="card-body bg-light">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Mã loại sản phẩm (*)</label>
                    <input type="text" class="form-control" @bind="model.Ma_LSP" placeholder="Ví dụ: 001, 002, 003..." />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Tên loại sản phẩm (*)</label>
                    <input type="text" class="form-control" @bind="model.Ten_LSP" placeholder="Ví dụ: Sản phẩm 1,..." />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Ghi chú</label>
                    <input type="text" class="form-control" @bind="model.Ghi_Chu" placeholder="Nhập ghi chú nếu có..." />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button class="btn w-100 text-white" style="background-color:#6f42c1" @onclick="HandleSave">
                        <i class="bi bi-save"></i> Lưu dữ liệu
                    </button>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(msg))
            {
                <div class="alert alert-info mt-2 py-1">@msg</div>
            }
        </div>
    </div> *@

    @if (showForm)
    {
        <div class="overlay">
            <div class="form-popup card shadow">
                <div class="card-header text-white" style="background:#6f42c1">
                    <h5>@(isEdit ? "Cập nhật" : "Thêm mới") loại sản phẩm</h5>
                </div>

                <div class="card-body">
                    <div class="mb-3">
                        <label>Mã loại sản phẩm</label>
                        <input class="form-control" @bind="model.Ma_LSP" placeholder="VD LSP001, LSP002,..."/>
                    </div>

                    <div class="mb-3">
                        <label>Tên loại sản phẩm</label>
                        <input class="form-control" @bind="model.Ten_LSP" placeholder="VD Sản phẩm 1,..."/>
                    </div>

                    <div class="mb-3">
                        <label>Ghi chú</label>
                        <input class="form-control" @bind="model.Ghi_Chu" placeholder="Nhập ghi chú nếu có"/>
                    </div>

                    <div class="d-flex justify-content-end gap-2">
                        <button class="btn btn-danger"
                                @onclick="() => {showForm = false; isEdit = false;}">
                            Hủy
                        </button>

                        <button class="btn text-white"
                                style="background:#6f42c1"
                                @onclick="HandleSave">
                            Lưu
                        </button>
                    </div>

                    @if (!string.IsNullOrEmpty(msg))
                    {
                        <div class="alert alert-info mt-2">@msg</div>
                    }
                </div>
            </div>
        </div>
    }

    @* Bảng hiển thị *@
    <div class="table-responsive">
        <table class="table table-striped table-hover border">
            <thead class="table-dark">
                <tr>
                    <th>Id</th>
                    <th>Mã loại sản phẩm</th>
                    <th>Tên loại sản phẩm</th>
                    <th>Ghi chú</th>
                    <th class="text-center" width="180">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (listData == null)
                {
                    <tr><td colspan="5" class="text-center">Đang tải dữ liệu từ API...</td></tr>
                }
                else if (listData.Count == 0)
                {
                    <tr><td colspan="5" class="text-center">Chưa có dữ liệu nào.</td></tr>
                }
                else
                {
                    foreach (var item in listData)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td>@item.Ma_LSP</td>
                            <td>@item.Ten_LSP</td>
                            <td>@item.Ghi_Chu</td>
                            <td class="text-center">
                                <button class="btn btn-sm btn-warning me-1" @onclick="() => LoadEdit(item)">Sửa</button>
                                <button class="btn btn-sm btn-danger" @onclick="() => Delete(item.Id)">Xóa</button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@code {

    private List<LoaiSanPhamDto>? listData;

    // List<LoaiSanPhamDto> listData = new List<LoaiSanPhamDto>
    // {
    //     new LoaiSanPhamDto{Id = 1,Ma_LSP = "001", Ten_LSP = "San Pham 1",Ghi_Chu = "Note"},
    //     new LoaiSanPhamDto{Id = 1,Ma_LSP = "002", Ten_LSP = "San Pham 2",Ghi_Chu = "Note"},
    //     new LoaiSanPhamDto{Id = 1,Ma_LSP = "003", Ten_LSP = "San Pham 3",Ghi_Chu = "Note"},
    //     new LoaiSanPhamDto{Id = 1,Ma_LSP = "004", Ten_LSP = "San Pham 4",Ghi_Chu = "Note"},
    //     new LoaiSanPhamDto{Id = 1,Ma_LSP = "005", Ten_LSP = "San Pham 5",Ghi_Chu = "Note"},
    // };

    private LoaiSanPhamDto model = new();
    private bool showForm = false;
    private string msg = "";
    private bool isEdit = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadList();
    }

    private async Task LoadList()
    {
        try
        {
            listData = await Http.GetFromJsonAsync<List<LoaiSanPhamDto>>("api/LoaiSanPham");
        }
        catch
        {
            msg = "Lỗi khi lấy dữ liệu loại sản phẩm";
        }
    }

    private async Task HandleSave()
    {
        if (string.IsNullOrEmpty(model.Ma_LSP))
        {
            msg = "Vui lòng nhập mã loại sản phẩm!";
            return;
        }

        if (string.IsNullOrEmpty(model.Ten_LSP))
        {
            msg = "Vui lòng nhập tên loại sản phẩm!";
            return;
        }

        if (isEdit)
        {
            try
            {
                await Http.PutAsJsonAsync($"api/LoaiSanPham/{model.Id}", model);
                msg = "Cập nhật thành công!";
            }
            catch
            {
                msg = "Lỗi khi cập nhật loại sản phẩm";
            }
        }
        else
        {
            try
            {
                var res = await Http.PostAsJsonAsync("api/LoaiSanPham", model);
                if (res.IsSuccessStatusCode) msg = "Thêm mới thành công!";
                else
                {
                    var error = await res.Content.ReadAsStringAsync();
                    msg = error;
                }
            }
            catch
            {
                msg = "Lỗi khi thêm loại sản phẩm";
            }
        }

        model = new();
        isEdit = false;
        await LoadList();
    }

    private void LoadEdit(LoaiSanPhamDto item)
    {
        model = new LoaiSanPhamDto { Id = item.Id, Ma_LSP = item.Ma_LSP, Ten_LSP = item.Ten_LSP, Ghi_Chu = item.Ghi_Chu };
        isEdit = true;
        showForm = true;
        msg = "Đang ở chế độ chỉnh sửa.";
    }

    private async Task Delete(int id)
    {
        bool confirm = await JS.InvokeAsync<bool>("confirm", "Bạn có chắc muốn xóa loại sản phẩm này?");
        if (confirm)
        {
            try
            {
                await Http.DeleteAsync($"api/LoaiSanPham/{id}");
                await LoadList();
            }
            catch
            {
                msg = "Lỗi khi xoá loại sản phẩm";
            }
        }
    }
}