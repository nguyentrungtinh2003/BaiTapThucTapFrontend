@page "/nha-cung-cap"
@using System.Net.Http.Json
@using BaiTapThucTapFrontend.Models
@inject HttpClient Http
@inject IJSRuntime JS

<div class="container-fluid">
    <h3 class="mt-3">Quản lý Nha cung cap</h3>

    @* Form nhập liệu nhanh *@
    <div class="card my-3">
        <div class="card-body bg-light">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Mã Nha cung cap (*)</label>
                    <input type="text" class="form-control" @bind="model.Ma_NCC" placeholder="Ví dụ: 001, 002, 003..." />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Tên Nha cung cap (*)</label>
                    <input type="text" class="form-control" @bind="model.Ten_NCC" placeholder="Ví dụ: Nha cung cap1,..." />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Ghi chú</label>
                    <input type="text" class="form-control" @bind="model.Ghi_Chu" placeholder="Nhập ghi chú nếu có..." />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button class="btn btn-primary w-100" @onclick="HandleSave">
                        <i class="bi bi-save"></i> Lưu dữ liệu
                    </button>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(msg))
            {
                <div class="alert alert-info mt-2 py-1">@msg</div>
            }
        </div>
    </div>

    @* Bảng hiển thị *@
    <div class="table-responsive">
        <table class="table table-striped table-hover border">
            <thead class="table-dark">
                <tr>
                    <th>Id</th>
                    <th>Mã Nha cung cap</th>
                    <th>Tên Nha cung cap</th>
                    <th>Ghi Chú</th>
                    <th class="text-center" width="180">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (listData == null)
                {
                    <tr><td colspan="3" class="text-center">Đang tải dữ liệu từ API...</td></tr>
                }
                else if (listData.Count == 0)
                {
                    <tr><td colspan="3" class="text-center">Chưa có dữ liệu nào.</td></tr>
                }
                else
                {
                    foreach (var item in listData)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td>@item.Ma_NCC</td>
                            <td>@item.Ten_NCC</td>
                            <td>@item.Ghi_Chu</td>
                            <td class="text-center">
                                <button class="btn btn-sm btn-warning me-1" @onclick="() => LoadEdit(item)">Sửa</button>
                                <button class="btn btn-sm btn-danger" @onclick="() => Delete(item.Id)">Xóa</button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@code {

    //private List<DonViTinhDto>? listData;

    List<NhaCungCapDto> listData = new List<NhaCungCapDto>
    {
        new NhaCungCapDto{Id = 1,Ma_NCC = "001", Ten_NCC = "Nha cung cap 1",Ghi_Chu = "Note"},
        new NhaCungCapDto{Id = 2,Ma_NCC = "002", Ten_NCC = "Nha cung cap 2",Ghi_Chu = "Note"},
        new NhaCungCapDto{Id = 3,Ma_NCC = "003", Ten_NCC = "Nha cung cap 3",Ghi_Chu = "Note"},
        new NhaCungCapDto{Id = 4,Ma_NCC = "004", Ten_NCC = "Nha cung cap 4",Ghi_Chu = "Note"},
        new NhaCungCapDto{Id = 5,Ma_NCC = "005", Ten_NCC = "Nha cung cap 5",Ghi_Chu = "Note"},
    };

    private NhaCungCapDto model = new();
    private string msg = "";
    private bool isEdit = false;

    // protected override async Task OnInitializedAsync()
    // {
    //     await LoadList();
    // }

    // private async Task LoadList()
    // {
    //     // Nhớ chỉnh lại "api/DonViTinh" cho đúng Route bên Backend của em
    //     listData = await Http.GetFromJsonAsync<List<DonViTinhDto>>("api/DonViTinh");
    // }

    private async Task HandleSave()
    {
        if (string.IsNullOrEmpty(model.Ma_NCC))
        {
            msg = "Vui lòng nhập mã nha cung cap!";
            return;
        }

        if (string.IsNullOrEmpty(model.Ten_NCC))
        {
            msg = "Vui lòng nhập tên nha cung cap!";
            return;
        }

        if (isEdit)
        {
            await Http.PutAsJsonAsync($"api/NhaCungCap/{model.Id}", model);
            msg = "Cập nhật thành công!";
        }
        else
        {
            var res = await Http.PostAsJsonAsync("api/NhaCungCap", model);
            if (res.IsSuccessStatusCode) msg = "Thêm mới thành công!";
            else msg = "Lỗi: Ma nha cung cap có thể đã tồn tại!";
        }

        model = new();
        isEdit = false;
        //await LoadList();
    }

    private void LoadEdit(NhaCungCapDto item)
    {
        model = new NhaCungCapDto { Id = item.Id, Ma_NCC = item.Ma_NCC, Ten_NCC = item.Ten_NCC, Ghi_Chu = item.Ghi_Chu };
        isEdit = true;
        msg = "Đang ở chế độ chỉnh sửa.";
    }

    private async Task Delete(int id)
    {
        bool confirm = await JS.InvokeAsync<bool>("confirm", "Bạn có chắc muốn xóa nha cung cap này?");
        if (confirm)
        {
            await Http.DeleteAsync($"api/NhaCungCap/{id}");
            // await LoadList();
        }
    }
}