    @if (showForm)
    {
        <div class="overlay">
            <div class="form-popup card shadow">
                <div class="card-header text-white" style="background:#6f42c1">
                    <h5>@(isEdit ? "Cập nhật" : "Thêm mới") nhà cung cấp</h5>
                </div>

                <div class="card-body">
                    <div class="mb-3">
                        <label>Mã nhà cung cấp</label>
                        <input class="form-control" @bind="model.Ma_NCC" placeholder="NCC001, NCC002,..."/>
                    </div>

                    <div class="mb-3">
                        <label>Tên nhà cung cấp</label>
                        <input class="form-control" @bind="model.Ten_NCC" placeholder="Nhà cung cấp 1,..."/>
                    </div>

                    <div class="mb-3">
                        <label>Ghi chú</label>
                        <input class="form-control" @bind="model.Ghi_Chu" placeholder="Nhập ghi chú nếu có"/>
                    </div>

                    <div class="d-flex justify-content-end gap-2">
                        <button class="btn btn-danger"
                                @onclick="() => {showForm = false; isEdit = false;}">
                            Hủy
                        </button>

                        <button class="btn text-white"
                                style="background:#6f42c1"
                                @onclick="HandleSave">
                            Lưu
                        </button>
                    </div>

                    @if (!string.IsNullOrEmpty(msg))
                    {
                        <div class="alert alert-info mt-2">@msg</div>
                    }
                </div>
            </div>
        </div>
    }

    @* Bảng hiển thị *@
    <div class="table-responsive">
        <table class="table table-striped table-hover border">
            <thead class="table-dark">
                <tr>
                    <th>Id</th>
                    <th>Mã nhà cung cấp</th>
                    <th>Tên nhà cung cấp</th>
                    <th>Ghi chú</th>
                    <th class="text-center" width="180">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (listData == null)
                {
                    <tr><td colspan="5" class="text-center">Đang tải dữ liệu từ API...</td></tr>
                }
                else if (listData.Count == 0)
                {
                    <tr><td colspan="5" class="text-center">Chưa có dữ liệu nào.</td></tr>
                }
                else
                {
                    foreach (var item in listData)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td>@item.Ma_NCC</td>
                            <td>@item.Ten_NCC</td>
                            <td>@item.Ghi_Chu</td>
                            <td class="text-center">
                                <button class="btn btn-sm btn-warning me-1" @onclick="() => LoadEdit(item)">Sửa</button>
                                <button class="btn btn-sm btn-danger" @onclick="() => Delete(item.Id)">Xóa</button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@code {

    private List<NhaCungCapDto>? listData;

    // List<NhaCungCapDto> listData = new List<NhaCungCapDto>
    // {
    //     new NhaCungCapDto{Id = 1,Ma_NCC = "001", Ten_NCC = "Nha cung cap 1",Ghi_Chu = "Note"},
    //     new NhaCungCapDto{Id = 2,Ma_NCC = "002", Ten_NCC = "Nha cung cap 2",Ghi_Chu = "Note"},
    //     new NhaCungCapDto{Id = 3,Ma_NCC = "003", Ten_NCC = "Nha cung cap 3",Ghi_Chu = "Note"},
    //     new NhaCungCapDto{Id = 4,Ma_NCC = "004", Ten_NCC = "Nha cung cap 4",Ghi_Chu = "Note"},
    //     new NhaCungCapDto{Id = 5,Ma_NCC = "005", Ten_NCC = "Nha cung cap 5",Ghi_Chu = "Note"},
    // };

    private NhaCungCapDto model = new();
    private bool showForm = false;
    private string msg = "";
    private bool isEdit = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadList();
    }

    private async Task LoadList()
    {
        try
        {
            listData = await Http.GetFromJsonAsync<List<NhaCungCapDto>>("api/NhaCungCap");
        }
        catch
        {
            msg = "Lỗi khi lấy thông tin nhà cung cấp";
        }
    }

    private async Task HandleSave()
    {
        if (string.IsNullOrEmpty(model.Ma_NCC))
        {
            msg = "Vui lòng nhập mã nhà cung cấp!";
            return;
        }

        if (string.IsNullOrEmpty(model.Ten_NCC))
        {
            msg = "Vui lòng nhập tên nhà cung cấp!";
            return;
        }

        if (isEdit)
        {
            try
            {
                await Http.PutAsJsonAsync($"api/NhaCungCap/{model.Id}", model);
                msg = "Cập nhật thành công!";
            }
            catch
            {
                msg = "Lỗi khi cập nhật nhà cung cấp";
            }
        }
        else
        {
            try
            {
                var res = await Http.PostAsJsonAsync("api/NhaCungCap", model);
                if (res.IsSuccessStatusCode) msg = "Thêm mới thành công!";
                else
                {
                    var error = await res.Content.ReadAsStringAsync();
                    msg = error;
                }
            }
            catch
            {
                msg = "Lỗi khi thêm nhà cung cấp";
            }
        }

        model = new();
        isEdit = false;
        await LoadList();
    }

    private void LoadEdit(NhaCungCapDto item)
    {
        model = new NhaCungCapDto { Id = item.Id, Ma_NCC = item.Ma_NCC, Ten_NCC = item.Ten_NCC, Ghi_Chu = item.Ghi_Chu };
        isEdit = true;
        showForm = true;
        msg = "Đang ở chế độ chỉnh sửa.";
    }

    private async Task Delete(int id)
    {
        bool confirm = await JS.InvokeAsync<bool>("confirm", "Bạn có chắc muốn xóa nhà cung cấp này?");
        if (confirm)
        {
            try
            {
                await Http.DeleteAsync($"api/NhaCungCap/{id}");
                await LoadList();
            }
            catch
            {
                msg = "Lỗi khi xoá nhà cung cấp";
            }
        }
    }
}