@page "/nha-cung-cap"
@using System.Net.Http.Json
@using BaiTapThucTapFrontend.Models
@inject HttpClient Http
@inject IJSRuntime JS
@rendermode InteractiveServer

<div class="container-fluid">
    <h3 class="mt-3">Quản Lý Nhà Cung Cấp</h3>

    <button class="btn text-white mb-3"
            style="background-color:#6f42c1"
            @onclick="() => showForm = true">
        + Thêm nhà cung cấp
    </button>

    @* Form nhập liệu nhanh *@
   @*  <div class="card my-3">
        <div class="card-body bg-light">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Mã nhà cung cấp (*)</label>
                    <input type="text" class="form-control" @bind="model.Ma_NCC" placeholder="Ví dụ: 001, 002, 003..." />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Tên nhà cung cấp (*)</label>
                    <input type="text" class="form-control" @bind="model.Ten_NCC" placeholder="Ví dụ: Nha cung cap1,..." />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Ghi chú</label>
                    <input type="text" class="form-control" @bind="model.Ghi_Chu" placeholder="Nhập ghi chú nếu có..." />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button class="btn w-100 text-white" style="background-color:#6f42c1" @onclick="HandleSave">
